# OpenAI
OPENAI_API_KEY="sk-..."
# Realtime model to use for the caller persona bot. Verify this string against
# OpenAI's current realtime model list before running — model ids change.
OPENAI_REALTIME_MODEL="gpt-realtime-2.1-mini"

# Twilio
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
# The Twilio number that will PLACE the calls (must be a number/trunk you own)
TWILIO_PHONE_NUMBER="+1..."

# The healthcare AI agent's test number we are calling (fixed target for this challenge)
TARGET_PHONE_NUMBER="+18054398008"

# Publicly reachable base URL for this machine's bridge server, e.g. an ngrok
# HTTPS URL like "https://abcd1234.ngrok-free.app". No trailing slash.
# Used both for the TwiML webhook (https) and the media WebSocket (wss).
PUBLIC_BASE_URL="https://your-tunnel.ngrok-free.app"

# Local port the bridge server listens on (should match your tunnel's target port)
PORT=8000
